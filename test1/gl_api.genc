

@table(Funcs) {

$cols = { ret name args }

>> comment 1
$rows = 
{ 
						>> comment3
  
	{ BOOL		 wgl_choose_pixel_format_arb		`HDC, const int*, const FLOAT*, UINT, int*, UINT*`                                }
	{ HGLRC		 wgl_create_context_attribs_arb		`HDC, HGLRC, const int*`                                                          }
	{ BOOL		 wgl_swap_interval_ext				`int interval`                                                                    }
	{ GLuint	 gl_create_shader					`GLenum type`                                                                     }
	{ void		 gl_shader_source					`GLuint shader, GLsizei count, const GLchar* const* string, const GLint* length`  }
	{ void		 gl_compile_shader					`GLuint shader`                                                                   }
	{ GLuint	 gl_create_program					`void`                                                                            }
	{ void		 gl_attach_shader					`GLuint program, GLuint shader`                                                   }
	{ void		 gl_link_program					`GLuint program`                                                                  }
	{ void		 gl_delete_shader					`GLuint shader`                                                                   }
	{ void		 gl_delete_program					`GLuint program`                                                                  }
	{ void		 gl_create_vertex_arrays			`GLsizei n, GLuint* arrays`                                                       }
	{ void		 gl_bind_vertex_array				`GLuint array`                                                                    }
	{ void		 gl_delete_vertex_arrays			`GLsizei n, const GLuint* arrays`                                                 }
	{ void		 gl_use_program						`GLuint program`                                                                  }
	{ void		 gl_get_shaderiv                    `GLuint shader, GLenum pname, GLint* params`                                      }
	{ void		 gl_get_shader_info_log             `GLuint shader, GLsizei bufSize, GLsizei* length, GLchar* infoLog`                }
	{ void		 gl_clear_bufferfv                  `GLenum buffer, GLint drawbuffer, const GLfloat* value`                           }
	{ void		 gl_vertex_attrib4fv                `GLuint index, const GLfloat* v`                                                  }
	{ void		 gl_vertex_attrib1f                 `GLuint index, const GLfloat x`                                                   }
	{ void		 gl_uniform_matrix4fv               `GLint location, GLsizei count, GLboolean transpose, const GLfloat* value`        }
	{ GLint		 gl_get_uniform_location            `GLuint program, const GLchar* name`                                              }
	{ void		 gl_get_programiv                   `GLuint program, GLenum pname, GLint* params`                                     }
	{ void		 gl_get_program_info_log            `GLuint program, GLsizei bufSize, GLsizei* length, GLchar* infoLog`               }
	{ void		 gl_validate_program                `GLuint program`                                                                  }
	{ void		 gl_vertex_attrib3fv                `GLuint index, const GLfloat* v`                                                  }
	{ void		 gl_generate_mipmap                 `GLenum target`                                                                   }
	{ void		 gl_uniform3fv                      `GLint location, GLsizei count, const GLfloat* value`                             }
	{ void		 gl_uniform1f                       `GLint location, GLfloat value`                                                   }

}

}



@func_types(OperationTypes) {
    @requires(Funcs f)

    $identifier = #concat(f.name, `_ft`)
    $args       = f.args
    $ret        = f.ret
}



@func_globals(OperationGlobals) {
    @requires(OperationTypes ot, Funcs f)

	$type = ot.identifier
    $identifier = #snake2camel(f.name)
}

@custom(OperationFuncLoader) {
    @requires(OperationGlobals og, OperationTypes ot)

    $template = `
internal void load_funcs() {
    {{range .}} {{.og.identifier}} = ({{.ot.identifier}} *)wglGetProcAddress("{{ snake2camel .og.identifier}}");
    {{end -}}
}
    `
}
